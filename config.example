# StravaStats for OpenWrt — configuration
# Copy to /etc/strava-leaderboard.conf and `chmod 600` it (it holds secrets).
# This file is sourced by /bin/sh, so use KEY="value" with no spaces around '='.

# --- Required: from your Strava API application -----------------------------
# Create one at https://www.strava.com/settings/api
STRAVA_CLIENT_ID="12345"
STRAVA_CLIENT_SECRET="0000000000000000000000000000000000000000"

# A long-lived refresh token authorized with the `activity:read` scope for a
# user who is a member of the club. See README.md "One-time authorization".
STRAVA_REFRESH_TOKEN="0000000000000000000000000000000000000000"

# One or more numeric club IDs, comma-separated. Taken from the club URL:
# https://www.strava.com/clubs/<id>  — the number at the end is the club id.
# To follow multiple clubs put them all here: STRAVA_CLUB_IDS="123456,789012"
# The old single-value STRAVA_CLUB_ID is still accepted for backward compatibility.
STRAVA_CLUB_IDS="123456,123457"

# --- Data source (choose one) ------------------------------------------------
# "api"    — default; OAuth-based, uses the Club Activities API.
#            The Club Activities endpoint is deprecated effective 2026-09-01.
#            Requires STRAVA_CLIENT_ID/SECRET/REFRESH_TOKEN above.
# "scrape" — web-session-based; uses the Strava club feed endpoint directly.
#            Switch to this after September 2026. Real activity dates + IDs.
#            Requires STRAVA_EMAIL and STRAVA_PASSWORD below; the OAuth vars
#            above are not used and can be left as placeholders.
#STRAVA_SOURCE="api"

# Required when STRAVA_SOURCE=scrape:
# Strava uses OTP/magic-link login — automated password auth is not possible.
# Instead, copy the _strava4_session cookie value from your already-logged-in
# browser: DevTools → Application → Cookies → www.strava.com → _strava4_session
# Sessions last ~30 days. When the script reports "cookie has expired", paste a
# fresh value here and the next run will re-verify automatically.
#STRAVA_SESSION_COOKIE="sm7ds67uj17reet9k7k54l0q83gl3oua"
#
# Cookie dry-run (STRAVA_SOURCE=api + STRAVA_SESSION_COOKIE set):
# You can set STRAVA_SESSION_COOKIE even while still using the API source. The
# script will verify the cookie on every run and display its status in the
# dashboard banner — no scraped data is saved. Use this to confirm the session
# is ready before switching to STRAVA_SOURCE=scrape after September 2026.

# --- Optional ---------------------------------------------------------------
# Filter to a single sport type (Run, Ride, Walk, Hike, ...). Empty = all.
STRAVA_SPORT_TYPE=""

# Strava access tokens last ~6h. The cached token is reused until it's within
# this many seconds of expiry, then refreshed. Bump it if a run could ever take
# longer than the gap between this and the 6h lifetime.
STRAVA_TOKEN_REFRESH_MARGIN="600"

# Date (YYYY-MM-DD) to stamp newly seen activities with. Defaults to today.
# Set this only to bootstrap the store: it attributes the activities the feed
# currently shows to the month they were really performed (e.g. 2026-05-15)
# instead of install day. Affects only activities added during that run, so set
# it for the first seeding run, then comment it back out for normal daily runs.
# STRAVA_FIRST_SEEN_DATE="2026-05-15"

# How many pages of the activities feed to pull (200 activities/page).
STRAVA_MAX_PAGES="5"
STRAVA_PER_PAGE="200"

# Where the dashboard is written (served by uhttpd at http://<router>/strava/).
# To spare the small flash overlay you may point this at roomy persistent
# storage (e.g. "/mnt/sda5/strava-leaderboard/web"); install.sh then symlinks
# the generated files back under /www/strava so uhttpd still serves them.
STRAVA_WEB_DIR="/www/strava"

# Where token state + dated JSON snapshots are kept. MUST be on persistent
# storage — on OpenWrt /tmp and /var live in RAM and are wiped on reboot.
STRAVA_STATE_DIR="/mnt/sda5/strava-leaderboard"

# How many daily JSON snapshots to retain before pruning the oldest.
STRAVA_KEEP_SNAPSHOTS="90"

# --- Network retry (optional) -----------------------------------------------
# On OpenWrt, dnsmasq restarts (e.g. during WAN reconnect) can cause a brief
# DNS gap. curl_retry in strava-lib.sh retries any network-level failure.
# STRAVA_CURL_RETRIES:      number of retries after the first attempt (default 3)
# STRAVA_CURL_RETRY_DELAY:  seconds to wait between retries (default 15)
#STRAVA_CURL_RETRIES="3"
#STRAVA_CURL_RETRY_DELAY="15"
